# Enviroment variables needed to connect to the LiveKit server.
LIVEKIT_API_KEY=<your_api_key>
LIVEKIT_API_SECRET=<your_api_secret>
LIVEKIT_URL=wss://<project-subdomain>.livekit.cloud

# Agent dispatch (https://docs.livekit.io/agents/server/agent-dispatch)
# Leave AGENT_NAME blank to enable automatic dispatch
# Provide an agent name to enable explicit dispatch
AGENT_NAME=

# Internally used environment variables
NEXT_PUBLIC_APP_CONFIG_ENDPOINT=
SANDBOX_ID=

# Bearer key for securing the chat history API endpoint
CHAT_API_BEARER_KEY=

# External API endpoint to fetch slash commands from
# If not set, built-in default commands are used
# Expected response format: { "commands": [{ "command": "/help", "description": "...", "example": "/help" }] }
COMMANDS_API_ENDPOINT=

# LM API configuration for model listing
# LM_API_KEY is required. LM_API_BASE_URL defaults to https://lm.portalos.ru
LM_API_KEY=
LM_API_BASE_URL=
